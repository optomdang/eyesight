# Production — copy giá trị vào Render / VPS (KHÔNG commit file .env thật).

NODE_ENV=production
PORT=4000

# Neon PostgreSQL (Dashboard → Connection details → không dùng pooled nếu migrate lỗi)
DB_HOST=ep-xxxx.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=your_neon_password
DB_NAME=neondb
DB_USE_SSL=true

# openssl rand -base64 48
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30

# Frontend production URL(s), phân cách bằng dấu phẩy
CORS_ORIGINS=https://app.nhuocthi.vn,https://nhuocthi.vn

# Tuỳ chọn — email / Zalo / TTS / Sentry
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@nhuocthi.vn
ZALO_ACCESS_TOKEN=
ZALO_APP_ID=
ZALO_APP_SECRET=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
