# Environment variables for Eye Sight Service with notification features

# Environment
NODE_ENV=development
PORT=4000

# Database (PostgreSQL local — docker compose -f docker-compose.db.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=eyesight
DB_PASSWORD=eyesight
DB_NAME=eyesight_local
DB_USE_SSL=false

# JWT
# JWT secret key
JWT_SECRET=thisisasamplesecret
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Email configuration (for exam notifications)
# For testing, you can use a fake SMTP service like Ethereal: https://ethereal.email/create
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@eyesight.com

# Zalo OA configuration (for Zalo notifications)
# Get these from Zalo Developers Console: https://developers.zalo.me/
ZALO_ACCESS_TOKEN=your_zalo_oa_access_token
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret

# CORS — production: comma-separated frontend URLs
# CORS_ORIGINS=https://app.nhuocthi.vn,https://nhuocthi.vn

# Cloud TTS preview (admin tool — optional, at least one to enable Cloud tab)
# Google: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_API_KEY=
# Azure: https://portal.azure.com → Speech service
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia
# ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
