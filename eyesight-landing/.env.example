# Site URL (production)
NEXT_PUBLIC_SITE_URL=https://nhuocthi.vn

# App login URL
NEXT_PUBLIC_APP_URL=https://app.nhuocthi.vn

# Zalo contact — phone number (digits only, e.g. 0912345678) or OA ID
NEXT_PUBLIC_ZALO_PHONE=

# Alternative: Zalo Official Account ID (if not using phone)
# NEXT_PUBLIC_ZALO_OA_ID=

# Payment (VietQR) — bank BIN + account for QR on registration step 5
# Bank BIN list: https://vietqr.io/portal-service/banks
NEXT_PUBLIC_PAYMENT_BANK_ID=
NEXT_PUBLIC_PAYMENT_ACCOUNT=
NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=

# Google Sheets webhook (Google Apps Script Web App URL)
NEXT_PUBLIC_GOOGLE_SHEETS_WEBHOOK_URL=

# Admin account for landing page management (/quan-ly/bac-si)
NEXT_PUBLIC_ADMIN_EMAIL=admin@nhuocthi.vn
NEXT_PUBLIC_ADMIN_PASSWORD=Admin@123
